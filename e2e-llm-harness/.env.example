# LLM endpoint (OpenAI-compatible). Any provider works as long as it speaks
# POST {LLM_BASE_URL}/chat/completions. For other providers, implement LLMClient.
LLM_BASE_URL=https://agentgo-qwen.changshininc.com/v1
LLM_MODEL=qwen3.5-122b
# LLM_API_KEY=sk-...            # omit if the server needs no auth
# Set to 1 for Qwen/vLLM "thinking" models to disable reasoning (faster, fills content).
LLM_NO_THINK=1
LLM_TIMEOUT_MS=60000
